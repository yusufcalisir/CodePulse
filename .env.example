# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codepulse:codepulse@localhost:5432/codepulse
DATABASE_URL_SYNC=postgresql://codepulse:codepulse@localhost:5432/codepulse

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── GitHub OAuth (create at https://github.com/settings/developers) ───
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# ─── GitHub API Token (for server-side data ingestion) ──────
GITHUB_TOKEN=ghp_your_personal_access_token

# ─── NextAuth ───────────────────────────────────────────────
AUTH_SECRET=generate_a_random_32_char_string_here
NEXTAUTH_URL=http://localhost:3000

# ─── Backend ────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ─── AI Insights (optional) ────────────────────────────────
# OPENAI_API_KEY=sk-...
